{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fastdash",
  "version": "0.1.0",
  "identifier": "co.zro.fastdash",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "fastdash",
        "width": 1120,
        "height": 740,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/saheer-ahamed/fastdash/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU0MzMyM0EyNjQ2MERCQTgKUldTbzIyQmtvaU16VkdFMjRUdTkvU3VrVjBuc2JWeVFQS21neE54RUJ0NC9YcnI0Q1dLSE1rRjAK"
    }
  }
}
