# Copy this file to `.env` and fill in the values, then build.
# These are read at BUILD time (by src-tauri/build.rs) and compiled into the app;
# they are also honored at runtime as a dev override without a rebuild.
# `.env` itself is gitignored - never commit real values.

# GitHub OAuth App client id for the "Connect with GitHub" Device Flow login.
# PUBLIC, not a secret: it only identifies the fastdash app to GitHub (the same
# value for every user). Register an OAuth App with "Enable Device Flow" checked
# at https://github.com/settings/developers and paste its Client ID here.
FASTDASH_GITHUB_CLIENT_ID=your_github_oauth_app_client_id
